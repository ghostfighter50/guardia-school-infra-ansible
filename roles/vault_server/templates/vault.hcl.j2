# {{ ansible_managed }}
# Vault - single-node, file storage, TLS disabled (lab only)

ui            = true
disable_mlock = true

storage "file" {
  path = "{{ vault_data_path }}"
}

listener "tcp" {
  address     = "{{ vault_listen_address }}:{{ vault_listen_port }}"
  tls_disable = 1
}

api_addr     = "{{ vault_api_addr }}"
cluster_addr = "{{ vault_cluster_addr }}"
